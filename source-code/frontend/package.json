  },
  "devDependencies": {
    "@oxlint/binding-linux-x64-gnu": "^1.75.0",
    "@rolldown/binding-linux-x64-gnu": "^1.1.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "oxlint": "^1.71.0",
