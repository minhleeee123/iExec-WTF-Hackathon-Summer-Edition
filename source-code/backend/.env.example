# Deployment, live E2E, and MCP signer. Never commit a real key.
PRIVATE_KEY=
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
KEEPER_HISTORY_RPC_URL=https://sepolia.drpc.org

# Stateless order keeper. A signer is only required outside dry-run mode.
KEEPER_PRIVATE_KEY=
KEEPER_POLL_INTERVAL_MS=15000
KEEPER_MAX_ACTIONS_PER_CYCLE=2
KEEPER_MIN_ETH=0.005
KEEPER_EXPIRE_ORDERS=true
KEEPER_DRY_RUN=false
KEEPER_HEALTH_PORT=8787
KEEPER_FINALITY_BLOCKS=12
KEEPER_HISTORY_HEAD_LAG_BLOCKS=3
KEEPER_CHECKPOINT_FILE=
NOTIFICATION_WEBHOOK_URL=
