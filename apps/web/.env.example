# Optional archive-capable Sepolia endpoint for lifecycle transaction links.
VITE_SEPOLIA_ARCHIVE_RPC_URL=https://sepolia.drpc.org

# Optional public URL for the stateless keeper GET /health endpoint.
VITE_KEEPER_HEALTH_URL=

# Server-side only. Never expose this as a VITE_ variable.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
# Shared secret required by the keeper-only /api/agent/observe endpoint.
KEEPER_OBSERVER_SECRET=
